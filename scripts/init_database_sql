
/*
--=================================================================
Create Database and Schemas
--=================================================================
Script Purpose:
	This script creates a new database 'DataWarehouse' under Master database after checking if it already exists.
	if the database exists then it is dropped and recreated. Additionally, the script sets up three new schemas.
	bronze, silver and gold.

WARNING:
	Running this script will drop database DataWarehouse and all the data will be permanently deleted.
*/

USE Master;
GO

-- Drop and recreate database 'DataWarehouse'

IF EXISTS (SELECT 1 FROM sys.databases WHERE name = 'DataWarehouse')
BEGIN
	ALTER DATABASE DataWarehouse SET SINGLE_USER WITH ROLLBACK IMMEDIATE
	DROP DATABASE DataWarehouse;
END;
GO

-- create DataWarehouse

CREATE DATABASE DataWarehouse;

USE DataWarehouse;

-- create Schemas

CREATE SCHEMA bronze;
GO
CREATE SCHEMA silver;
GO
CREATE SCHEMA gold;
GO
